{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default Hone capabilities (bundled + Vite dev server)",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:5173",
      "http://localhost:5173/**",
      "http://127.0.0.1:5173",
      "http://127.0.0.1:5173/**"
    ]
  },
  "permissions": [
    "core:default",
    "shell:allow-open",
    "deep-link:default",
    "store:default",
    "allow-hone-commands"
  ]
}
