{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default Hone capabilities (bundled + Vite dev server)",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:5173",
      "http://localhost:5173/**",
      "http://127.0.0.1:5173",
      "http://127.0.0.1:5173/**"
    ]
  },
  "permissions": [
    "core:default",
    "shell:allow-open",
    "deep-link:default",
    "store:default",
    "allow-hone-commands",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://druz9.online/**" },
        { "url": "https://api.druz9.online/**" },
        { "url": "https://cdn.druz9.online/**" },
        { "url": "https://druz9.ru/**" },
        { "url": "http://localhost:8080/**" },
        { "url": "http://127.0.0.1:8080/**" }
      ]
    }
  ]
}
