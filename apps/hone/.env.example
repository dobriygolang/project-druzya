# Copy to `.env` for local dev:  cp .env.example .env

# Default: prod API (https://druz9.online) via Vite proxy — no local backend needed.

# Local microservices stack (identity + tracker + notes + focus):
# VITE_HONE_LOCAL_API=true
# HONE_API_BASE=http://localhost:8080

# Fallback bot username (login button deep-link):
VITE_TELEGRAM_BOT_USERNAME=druz9_bot

# Dev login UI at the bottom of the login screen:
VITE_HONE_DEV_LOGIN=true
