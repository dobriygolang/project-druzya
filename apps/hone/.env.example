# Copy to `.env`:  cp .env.example .env

# Default: prod API (https://druz9.online) via Vite proxy — no local backend needed.

# Direct API base (skip proxy). Usually leave unset in dev.
# VITE_DRUZ9_API_BASE=http://localhost:8080

# Local microservices stack (identity, tracker, notes, focus):
# VITE_HONE_LOCAL_API=true

# Telegram bot @username fallback when /v1/auth/config fails:
VITE_TELEGRAM_BOT_USERNAME=druz9_bot

# Dev login panel on login screen (identity DEV_AUTH=true on backend):
VITE_HONE_DEV_LOGIN=true

# Public web companion URL:
# VITE_DRUZ9_WEB_BASE=http://localhost:5173

# RPC debug bearer (optional):
# VITE_DRUZ9_DEV_TOKEN=
