# API base path (production: same-origin /v1 via Caddy)
VITE_API_BASE=/v1

# Shown on login when /v1/auth/config is unavailable
VITE_TELEGRAM_BOT_USERNAME=

# Friends desktop download (optional — landing resolves latest GitHub release automatically)
# VITE_HONE_DOWNLOAD_MAC=https://example.com/Friends.dmg
# VITE_HONE_DOWNLOAD_WIN=https://example.com/Friends-setup.exe

# Canonical site URL for SEO meta tags (production default: https://druz9.online)
# VITE_SITE_ORIGIN=https://druz9.online

# Landing hero media (optional — falls back to animated preview)
# VITE_HONE_HERO_VIDEO=/hero.mp4
# VITE_HONE_HERO_POSTER=/hero-poster.jpg

# Per-service overrides for vite dev proxy
# VITE_IDENTITY_URL=http://localhost:8080
# VITE_BILLING_URL=http://localhost:8085
# VITE_SANDBOX_URL=http://localhost:8086
# VITE_ROOMS_URL=http://localhost:8087
