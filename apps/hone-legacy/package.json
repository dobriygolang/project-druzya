{
  "name": "hone",
  "productName": "Hone",
  "version": "0.0.1",
  "description": "Hone — minimal dark desktop focus cockpit for developers (druz9 ecosystem)",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite",
    "dev:electron": "electron-vite dev",
    "build": "tauri build",
    "build:vite": "vite build",
    "build:electron": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac-dev": "electron-vite build && electron-builder --mac dir --arm64 --config.mac.identity=null --config.mac.hardenedRuntime=false --config.mac.gatekeeperAssess=false && codesign --force --deep --sign - 'dist/mac-arm64/Hone.app'",
    "lint": "eslint 'src/**/*.{ts,tsx,jsx}'",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "1.10.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@connectrpc/connect": "^1.4.0",
    "@connectrpc/connect-web": "^1.4.0",
    "@excalidraw/excalidraw": "^0.18.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@sentry/electron": "^7.11.0",
    "@tauri-apps/api": "^2.2.0",
    "electron-updater": "^6.3.9",
    "marked": "^18.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tldraw": "^4.5.10",
    "y-codemirror.next": "^0.3.5",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@tauri-apps/cli": "^2.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "41.2.2",
    "electron-builder": "26.8.1",
    "electron-vite": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.15.0",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.9"
  }
}
