# Hone desktop — Vite renderer config.
# Copy to .env (gitignored) and tune for local dev.

# Backend monolith. Default in dev = http://localhost:8080 (matches `make start`).
VITE_DRUZ9_API_BASE=http://localhost:8080

# Public web. Default in dev = http://localhost:5173 (matches `make front`).
VITE_DRUZ9_WEB_BASE=http://localhost:5173

# Skip OAuth in dev: paste any user's bearer to bypass login.
# VITE_DRUZ9_DEV_TOKEN=

# Pro upgrade landing override (rare).
# VITE_DRUZ9_PRO_URL=https://druz9.online/upgrade
# VITE_DRUZ9_BYOK_URL=https://druz9.online/byok
