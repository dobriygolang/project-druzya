{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@renderer/*": ["./src/renderer/src/*"],
      "@generated/*": ["../frontend/src/api/generated/*"],
      "@d9-i18n": ["../shared/i18n"],
      "@d9-i18n/*": ["../shared/i18n/*"],
      "zustand": ["./node_modules/zustand"],
      "zustand/*": ["./node_modules/zustand/*"],
      "@bufbuild/protobuf": ["./node_modules/@bufbuild/protobuf"],
      "@connectrpc/connect": ["./node_modules/@connectrpc/connect"],
      "@connectrpc/connect-web": ["./node_modules/@connectrpc/connect-web"]
    }
  },
  "include": ["src/renderer/**/*", "src/preload/**/*", "src/shared/**/*", "src/test/**/*", "../shared/i18n/**/*"],
  "exclude": ["src/main/**/*", "out", "dist", "node_modules"]
}
