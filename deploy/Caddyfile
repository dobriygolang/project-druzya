{
	email {$CADDY_EMAIL}
	# Host nginx keeps :80/:443 (e.g. VPN). TLS terminates in nginx; Caddy is HTTP-only behind it.
	auto_https off
}

# Shared API routing (used on api.* and on the SPA host for same-origin /v1).
(api_v1) {
	handle /v1/auth* {
		reverse_proxy identity:8080
	}
	handle /v1/me* {
		reverse_proxy identity:8080
	}
	handle /v1/users* {
		reverse_proxy identity:8080
	}
	handle /v1/jwt* {
		reverse_proxy identity:8080
	}
	handle /v1/companies* {
		reverse_proxy content:8081
	}
	handle /v1/interview-templates* {
		reverse_proxy content:8081
	}
	handle /v1/tasks* {
		reverse_proxy content:8081
	}
	handle /v1/rubrics* {
		reverse_proxy content:8081
	}
	handle /v1/interview* {
		reverse_proxy interview:8082
	}
	handle /v1/recommendations* {
		reverse_proxy recommendation:8084
	}
	handle /v1/rooms* {
		reverse_proxy rooms:8087
	}
	handle /v1/sandbox* {
		reverse_proxy sandbox:8086
	}
	handle /v1/billing* {
		reverse_proxy billing:8085
	}
	handle /v1/* {
		header Content-Type application/json
		respond "{\"error\":\"not found\"}" 404
	}
}

(api_ws) {
	handle /ws/lsp/* {
		reverse_proxy sandbox:8086
	}
	handle /ws/* {
		reverse_proxy rooms:8087
	}
}

# API — primary: api.druz9.online; mirror: api.druz9.ru
http://api.druz9.online, http://api.druz9.ru {
	encode gzip
	import api_v1
	import api_ws
	handle /healthz {
		respond "ok" 200
	}
	respond "not found" 404
}

# SPA — canonical: druz9.online (same-origin /v1 for VITE_API_BASE=/v1)
http://druz9.online, http://app.druz9.online {
	encode gzip
	route {
		import api_v1
		import api_ws
		handle {
			root * /srv
			try_files {path} /index.html
			file_server
		}
	}
}

# RU apex + app → canonical .online
http://druz9.ru, http://app.druz9.ru {
	redir https://druz9.online{uri} permanent
}
