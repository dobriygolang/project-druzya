prometheus.scrape "notes" {
  targets    = [{ __address__ = "notes:8090" }]
  forward_to = [prometheus.remote_write.grafana_cloud.receiver]
  job_name   = "notes"
}

prometheus.scrape "focus" {
  targets    = [{ __address__ = "focus:8091" }]
  forward_to = [prometheus.remote_write.grafana_cloud.receiver]
  job_name   = "focus"
