# =============================================================================
# druz9 production — copy to deploy/.env and fill values
# cp deploy/.env.example deploy/.env
# =============================================================================

APP_ENV=production
LOG_LEVEL=info
GRPC_HOST=0.0.0.0

# openssl rand -hex 32
INTERNAL_API_TOKEN=CHANGE_ME

POSTGRES_USER=druzya
POSTGRES_PASSWORD=CHANGE_ME

IDENTITY_POSTGRES_DSN=postgres://druzya:CHANGE_ME@postgres:5432/druzya?sslmode=disable
CONTENT_POSTGRES_DSN=postgres://druzya:CHANGE_ME@postgres:5432/druzya_content?sslmode=disable
INTERVIEW_POSTGRES_DSN=postgres://druzya:CHANGE_ME@postgres:5432/druzya_interview?sslmode=disable
AI_POSTGRES_DSN=postgres://druzya:CHANGE_ME@postgres:5432/druzya_ai?sslmode=disable
RECOMMENDATION_POSTGRES_DSN=postgres://druzya:CHANGE_ME@postgres:5432/druzya_recommendation?sslmode=disable
BILLING_POSTGRES_DSN=postgres://druzya:CHANGE_ME@postgres:5432/druzya_billing?sslmode=disable
TRIBUTE_WEBHOOK_SECRET=
# When empty, /v1/billing/webhooks/tribute returns 401 until you set a secret.
TRIBUTE_TIER_MAP=tribute_pro_monthly:pro_monthly
# Tribute Creator → Links → Web / Telegram Mini App (shown on /pricing).
TRIBUTE_PRO_CHECKOUT_URL=
TRIBUTE_PRO_TELEGRAM_CHECKOUT_URL=
# Optional multi-plan maps (plan_slug=https://..., use = not : — URLs contain colons):
# TRIBUTE_CHECKOUT_URLS=pro_monthly=https://web.tribute.tg/p/XXX
# TRIBUTE_TELEGRAM_CHECKOUT_URLS=pro_monthly=https://t.me/tribute/app?startapp=XXX
# Webhook URL in Tribute dashboard: https://api.druz9.online/v1/billing/webhooks/tribute

# One-time Pro trial promo (shown on /pricing, POST /v1/billing/trial/start).
PRO_TRIAL_ENABLED=true
PRO_TRIAL_DAYS=14
# Optional Redis entitlements cache (billing service; shared redis with identity).
ENTITLEMENTS_CACHE_TTL=60s
# AI exact prompt hash cache (shared redis L2 in prod).
LLM_PROMPT_CACHE=on
LLM_PROMPT_CACHE_MAX_ENTRIES=1000
LLM_PROMPT_CACHE_TTL=24h
SANDBOX_POSTGRES_DSN=postgres://druzya:CHANGE_ME@postgres:5432/druzya_sandbox?sslmode=disable
ROOMS_POSTGRES_DSN=postgres://druzya:CHANGE_ME@postgres:5432/druzya_rooms?sslmode=disable
ROOM_INVITE_SECRET=CHANGE_ME
GUEST_ROOM_TTL=1h
ROOM_ARCHIVE_INTERVAL=1m
PUBLIC_BASE_URL=https://druz9.online
SANDBOX_RUNNER_MODE=docker
SANDBOX_ASYNC_RUNS=auto
SANDBOX_MAX_OUTPUT_BYTES=65536
SANDBOX_DEFAULT_TIMEOUT_MS=10000
SANDBOX_DOCKER_GO_IMAGE=golang:1.24-alpine
SANDBOX_DOCKER_PYTHON_IMAGE=python:3.12-alpine
SANDBOX_DOCKER_NODE_IMAGE=node:22-alpine
# Host dir for docker runner bind mounts (must match deploy/docker-compose.prod.yml volume).
# mkdir -p /var/lib/sandbox-work && chmod 700 /var/lib/sandbox-work

# openssl rand -hex 32 — separate token for content admin RPCs
ADMIN_API_TOKEN=CHANGE_ME
# Comma-separated identity user UUIDs allowed to use /v1/admin/*
ADMIN_USER_IDS=00000000-0000-0000-0000-000000000001

FRONTEND_URL=https://druz9.online
CORS_ALLOWED_ORIGINS=https://druz9.online,https://app.druz9.online,https://druz9.ru,https://app.druz9.ru
AUTH_RATE_LIMIT_PER_MINUTE=60

TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_BOT_USERNAME=CHANGE_ME_bot

YANDEX_CLIENT_ID=CHANGE_ME
YANDEX_CLIENT_SECRET=CHANGE_ME
YANDEX_REDIRECT_URI=https://api.druz9.online/v1/auth/yandex/callback

# =============================================================================
# LLM — free vs pro split (see deploy/RUNBOOK.md § Paid LLM)
# =============================================================================
#
# Free users → LLM_FREE_CHAIN_ORDER + GROQ_API_KEY (free tier) / CLOUDFLARE / OPENROUTER
# Pro users  → LLM_PAID_CHAIN_ORDER + GROQ_PAID_API_KEY / DEEPSEEK_API_KEY / OPENROUTER_PAID_API_KEY
#
LLM_CHAIN_ORDER=groq,cloudflare,openrouter
LLM_FREE_CHAIN_ORDER=groq,cloudflare,openrouter
LLM_PAID_CHAIN_ORDER=deepseek,groq
GROQ_API_KEY=
GROQ_PAID_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_PAID_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
LLM_CAVEMAN=lite

EVAL_WORKER_CONCURRENCY=20
WORKER_POLL_INTERVAL=2s
EVAL_MAX_RETRIES=3

# Outbox relay (NATS) — prod compose defaults: relay on, poll off
NATS_URL=nats://nats:4222
OUTBOX_RELAY_ENABLED=true
OUTBOX_POLL_ENABLED=false

SESSION_TTL=8h
SESSION_STALE_AFTER=45m
SESSION_CLEANUP_INTERVAL=5m
TRAINING_TASK_LIMIT=10

CADDY_EMAIL=admin@druz9.ru
# Caddy HTTP on localhost only (host nginx keeps 80/443 for VPN). See deploy/nginx-druz9.conf.example.
CADDY_HTTP_PORT=18080

# Grafana Cloud (optional — enable with: docker compose --profile monitoring up -d alloy)
# Get credentials: Grafana Cloud → Connections → Prometheus → Remote write
GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_PROMETHEUS_USER=
GRAFANA_CLOUD_PROMETHEUS_API_KEY=
GRAFANA_CLOUD_STACK_URL=
GRAFANA_CLOUD_API_KEY=
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=https://grafana.druz9.online/
